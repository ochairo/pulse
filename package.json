{
  "name": "@ochairo/pulse",
  "version": "0.2.0",
  "description": "Path-aware reactive runtime with explicit get/set/on semantics",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.*",
    "!dist/**/*.map",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "pnpm clean && tsc && pnpm build:minify",
    "build:minify": "esbuild dist/index.js --outdir=dist --format=esm --allow-overwrite --minify --legal-comments=none --tree-shaking=true",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:types": "tsc -p tsconfig.type-tests.json",
    "validate": "pnpm test && pnpm typecheck && pnpm typecheck:types && pnpm build",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "pulse",
    "reactive",
    "reactivity",
    "state-management",
    "signals",
    "ochairo"
  ],
  "author": "ochairo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ochairo/pulse"
  },
  "homepage": "https://github.com/ochairo/pulse#readme",
  "bugs": {
    "url": "https://github.com/ochairo/pulse/issues"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "esbuild": "^0.27.2",
    "typescript": "^5.3.3",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
